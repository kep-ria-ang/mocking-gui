{
  "name": "@kakaocloud/mocking-gui",
  "version": "1.0.2",
  "description": "GUI library for MSW-based API mocking with an interactive panel",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./style.css": "./dist/mocking-gui.css"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ],
      "browser": [
        "dist/browser.d.ts"
      ],
      "server": [
        "dist/server.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "private": false,
  "scripts": {
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "msw:init": "npx msw init public/ --save",
    "release": "release-it --ci"
  },
  "keywords": [
    "msw",
    "mock",
    "gui",
    "panel",
    "react",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kakaoenterprise/mocking-gui.git",
    "directory": "packages/mocking-gui"
  },
  "peerDependencies": {
    "msw": "^2.8.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.294.0",
    "react-json-view": "^1.21.3",
    "react-resizable-panels": "^3.0.6",
    "tailwind-merge": "^2.6.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@release-it/bumper": "^7.0.5",
    "@mocking-gui/eslint-config": "workspace:*",
    "@mocking-gui/typescript-config": "workspace:*",
    "@tailwindcss/vite": "4.1.11",
    "@types/node": "24.0.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "chokidar-cli": "^3.0.0",
    "globals": "^16.3.0",
    "postcss": "^8.4.32",
    "prettier": "3.6.2",
    "release-it": "^19.0.3",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.36.0",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^3.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^1.0.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
